DJANGO_SECRET_KEY=replace-with-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.onrender.com
DATABASE_URL=postgres://username:password@host:5432/dbname
DB_CONN_MAX_AGE=60

CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

MAX_AVATAR_UPLOAD_SIZE=5242880

# Optional for serving media files directly from Django in production.
SERVE_MEDIA_FILES=True
# If using Render persistent disk, mount path can be /var/data/media
DJANGO_MEDIA_ROOT=/var/data/media

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep in one line with escaped \n
FIREBASE_PRIVATE_KEY=

LOG_LEVEL=INFO
